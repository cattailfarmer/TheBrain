  @ [sjs_protocol] C:\Project\ReasoningFramework\platform\refinement\Specification_Justification_Solution.sop
  @ [data_driven_design_protocol] C:\Project\ReasoningFramework\platform\refinement\Data_Driven_Design.sop

  + [source_snapshot_uuid] is 7f0d2d53-b8dc-4cb3-b7b9-8a7e35d5d82c
  + [signature_protocol_uuid] is ad10f10f-d506-48ef-a805-f8b0a133766c
